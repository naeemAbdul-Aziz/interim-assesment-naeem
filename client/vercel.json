  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://naeem-crypto-api.onrender.com/api/$1" },
    { "source": "/register", "destination": "https://naeem-crypto-api.onrender.com/register" },
    { "source": "/login", "destination": "https://naeem-crypto-api.onrender.com/login" },
    { "source": "/profile", "destination": "https://naeem-crypto-api.onrender.com/profile" },
    { "source": "/crypto", "destination": "https://naeem-crypto-api.onrender.com/crypto" },
